// Frontend environment configuration
// Copy to .env and adjust for your deployment

// Backend API base URL (no trailing slash)
VITE_API_BASE_URL=http://localhost:8000

// WebSocket base URL (use ws:// for local, wss:// for production)
VITE_WS_BASE_URL=ws://localhost:8000

// API Key (must match backend API_KEY setting)
VITE_API_KEY=dev-secret-api-key

// Supabase — from Supabase dashboard > Settings > API
// VITE_SUPABASE_URL and VITE_SUPABASE_ANON_KEY must be set for auth to work
// DO NOT put SUPABASE_JWT_SECRET here — backend only!
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key
